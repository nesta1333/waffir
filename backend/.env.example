# ═══════════════════════════════════════════════════════════════════
#  وفّر (Waffir) — Backend Environment Variables
#  Copy this file to .env and fill in your real credentials.
#  Never commit .env to version control.
# ═══════════════════════════════════════════════════════════════════

# ── Infrastructure ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# PostgreSQL — required for user auth + persistent alerts
# Local:   postgresql+asyncpg://waffir:secret@localhost:5432/waffir
# Render:  set automatically via render.yaml
DATABASE_URL=postgresql+asyncpg://waffir:secret@localhost:5432/waffir

# ── Auth (JWT) ──────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string
TOKEN_EXPIRE_DAYS=30

# ── SMS — Twilio (اختياري — بدونه الرمز يُطبع في السجل فقط) ─────────
# سجّل مجاناً على twilio.com ← Console ← Project Info
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# رقم Twilio الافتراضي (تحصل عليه مجاناً عند التسجيل)
TWILIO_PHONE_FROM=+1XXXXXXXXXX

# ══════════════════════════════════════════════════════════════════
# ── Google Search — المحرك الرئيسي لجلب البيانات (بدون login) ──
# ══════════════════════════════════════════════════════════════════
#
# الخيار الموصى به: Serper.dev
#   1. اذهب إلى serper.dev
#   2. سجّل مجاناً (2500 بحث/شهر مجاناً)
#   3. انسخ API Key وضعه هنا:
SERPER_API_KEY=
#
# الخيار البديل: Google Custom Search API (100 بحث/يوم مجاناً)
#   1. console.developers.google.com → Enable "Custom Search API"
#   2. cse.google.com → Create engine → أضف: amazon.ae, noon.com, namshi.com, temu.com
#   3. احصل على API Key + Search Engine ID:
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
#
# بدون أي مفتاح: التطبيق يعمل لكن بدون نتائج حقيقية (وضع تطوير فقط)

# ── API Settings ────────────────────────────────────────────────────
CORS_ORIGINS=*
WORKERS=2
LOG_LEVEL=INFO

# Browser profile storage (Playwright session persistence)
BROWSER_PROFILE_DIR=./browser_profiles

# ── Amazon.ae ───────────────────────────────────────────────────────
# 5-account rotation (only _1 is required minimum)
AMAZON_EMAIL_1=your_amazon_email_1@example.com
AMAZON_PASS_1=your_amazon_password_1
AMAZON_EMAIL_2=
AMAZON_PASS_2=
AMAZON_EMAIL_3=
AMAZON_PASS_3=
AMAZON_EMAIL_4=
AMAZON_PASS_4=
AMAZON_EMAIL_5=
AMAZON_PASS_5=

# ── Noon.com ────────────────────────────────────────────────────────
NOON_EMAIL_1=your_noon_email_1@example.com
NOON_PASS_1=your_noon_password_1
NOON_EMAIL_2=
NOON_PASS_2=
NOON_EMAIL_3=
NOON_PASS_3=

# ── Namshi ──────────────────────────────────────────────────────────
NAMSHI_EMAIL_1=your_namshi_email@example.com
NAMSHI_PASS_1=your_namshi_password

# ── AliExpress Affiliate API ─────────────────────────────────────────
# Apply at: https://portals.aliexpress.com/  (free tier: 5,000 calls/day)
ALIEXPRESS_APP_KEY=your_app_key_here
ALIEXPRESS_APP_SECRET=your_app_secret_here
ALIEXPRESS_TRACKING_ID=waffir

# ── Temu ─────────────────────────────────────────────────────────────
# No account needed. Optional proxy to reduce blocks:
# TEMU_PROXY=http://user:pass@proxy.host:port

# ── Expo Push Notifications ──────────────────────────────────────────
# Get token at: https://expo.dev/accounts/[username]/settings/access-tokens
EXPO_ACCESS_TOKEN=

# ── Optional proxies for scraping ────────────────────────────────────
# HTTP_PROXY=http://user:pass@proxy:port
# HTTPS_PROXY=http://user:pass@proxy:port
